{
  "version": 2,
  "builds": [
    { "src": "apps/api/main.py", "use": "@vercel/python" },
    { "src": "apps/web/package.json", "use": "@vercel/next" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/apps/api/main.py" },
    { "source": "/(.*)", "destination": "/apps/web/$1" }
  ],
  "functions": {
    "apps/api/*.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
